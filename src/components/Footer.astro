---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <span class="footer-copy">© {year} CAPP GAMES</span>
    <div class="footer-links">
      <a href="/about">About</a>
      <a href="/about">Contact</a>
      <a href="https://boardgamegeek.com/profile/cappgames" target="_blank" rel="noopener">CAPP GAMES on BGG</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-copy {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--text-dim);
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--text-dim);
    font-size: 0.85rem;
    transition: color 0.2s;
    text-decoration: none;
  }
  .footer-links a:hover { color: var(--gold); }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
