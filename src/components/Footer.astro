---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <span class="footer-copy">© {year} CAPP GAMES</span>
      <a href="https://ko-fi.com/cappgames" target="_blank" rel="noopener" class="kofi-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.349 2.658-3.886-.025-1.502-.157-1.996-.157-1.996 0 0 3.555.07 5.063-1.583 1.498-1.645.576-3.185.576-3.185zm-13.37 7.214h-2.141V7.571h2.141v8.591zm3.855 0h-2.141v-5.56h2.141v5.56zm0-7.697h-2.141V6.276h2.141v2.189zm4.965 7.697h-2.141v-2.756l-2.141-3.066h2.523l.879 1.614.879-1.614h2.523l-2.141 3.066v2.756h-.381z"/>
        </svg>
        Support
      </a>
    </div>
    <div class="footer-links">
      <a href="/about">About</a>
      <a href="/about#contact">Contact</a>
      <a href="/terms">Terms of Service</a>
      <a href="https://boardgamegeek.com/profile/cappgames" target="_blank" rel="noopener">CAPP GAMES on BGG</a>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-copy {
    font-family: 'Cinzel', serif;
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--text-dim);
  }

  .kofi-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: #FF5E5B;
    border: 1px solid rgba(255,94,91,0.35);
    border-radius: 6px;
    padding: 0.15rem 0.55rem;
    font-size: 0.78rem;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .kofi-link:hover {
    background: rgba(255,94,91,0.1);
    border-color: #FF5E5B;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--text-dim);
    font-size: 0.85rem;
    transition: color 0.2s;
    text-decoration: none;
  }
  .footer-links a:hover { color: var(--gold); }

  @media (max-width: 640px) {
    .footer-inner {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .footer-links { flex-wrap: wrap; justify-content: center; }
  }
</style>
