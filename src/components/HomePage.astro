---
import { useTranslations, type Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<!-- ─── Products ─────────────────────────────────────────── -->
<section class="products">
  <div class="container">
    <div class="section-header">
      <h2>{t('home.ourGames')}</h2>
      <div class="gold-divider"></div>
    </div>

    <!-- Fantasy Arena — featured -->
    <div class="card product-card product-card-featured">
      <a href="/video-games/fantasy-arena" class="card-overlay-link" aria-label={t('home.fa.ariaLabel')}></a>
      <div class="featured-img-wrap fa-hex-card">
        <svg class="fa-hex-svg" viewBox="0 0 600 200" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <radialGradient id="fa-bg" cx="50%" cy="50%" r="70%">
              <stop offset="0%" stop-color="#0d1530"/>
              <stop offset="100%" stop-color="#050b18"/>
            </radialGradient>
            <radialGradient id="fa-glow" cx="50%" cy="50%" r="40%">
              <stop offset="0%" stop-color="rgba(91,175,245,0.12)"/>
              <stop offset="100%" stop-color="rgba(91,175,245,0)"/>
            </radialGradient>
            <pattern id="hexgrid" x="25" y="0" width="150" height="86.6" patternUnits="userSpaceOnUse">
              <polygon points="50,0 25,43.3 -25,43.3 -50,0 -25,-43.3 25,-43.3" fill="none" stroke="rgba(91,175,245,0.22)" stroke-width="1.5"/>
              <polygon points="125,43.3 100,86.6 50,86.6 25,43.3 50,0 100,0" fill="none" stroke="rgba(91,175,245,0.22)" stroke-width="1.5"/>
            </pattern>
          </defs>
          <rect width="600" height="200" fill="url(#fa-bg)"/>
          <rect width="600" height="200" fill="url(#hexgrid)"/>
          <rect width="600" height="200" fill="url(#fa-glow)"/>
        </svg>
        <div class="fa-overlay-content">
          <div class="fa-heroes">
            <span>&#9876;&#65039;</span>
            <span>&#129497;</span>
            <span>&#127993;</span>
            <span>&#128154;</span>
            <span>&#128481;&#65039;</span>
          </div>
          <span class="fa-label">Auto-Chess: Fantasy Arena</span>
        </div>
      </div>
      <div class="card-body">
        <div class="featured-tags">
          <span class="tag tag-blue">{t('home.fa.tagBrowser')}</span>
          <span class="tag tag-update">{t('home.fa.tagUpdate')}</span>
        </div>
        <h3 class="featured-title">Auto-Chess: Fantasy Arena</h3>
        <p class="card-desc">{t('home.fa.desc1')}</p>
        <p class="card-desc update-teaser">{t('home.fa.desc2')}</p>
        <div class="featured-actions">
          <a href="https://fantasy-arena-iota.vercel.app" target="_blank" rel="noopener" class="btn btn-gold play-now-btn">{t('home.fa.playNow')}</a>
          <a href="/video-games/fantasy-arena" class="card-cta details-link">{t('home.fa.moreInfo')}</a>
        </div>
      </div>
    </div>

    <!-- Board games row -->
    <div class="board-games-row">

      <!-- Ransack -->
      <a href="/board-games/ransack" class="card product-card">
        <div class="card-img-wrap">
          <img src="/images/ransack-cover.webp" alt="Ransack board game box cover" class="card-img card-img-down" loading="lazy" />
        </div>
        <div class="card-body">
          <span class="tag tag-gold">{t('home.ransack.tag')}</span>
          <h3>Ransack</h3>
          <p class="card-desc">{t('home.ransack.desc')}</p>
          <span class="card-cta">{t('home.ransack.cta')}</span>
        </div>
      </a>

      <!-- New game (unnamed) -->
      <a href="/board-games/new-game" class="card product-card product-card-soon">
        <div class="card-img-wrap">
          <img src="/images/UpcomingWaterGame.webp" alt="New water-themed board game in development" class="card-img" loading="lazy" />
        </div>
        <div class="card-body">
          <span class="tag tag-gray">{t('home.newGame.tag')}</span>
          <h3>{t('home.newGame.title')}</h3>
          <p class="card-desc">{t('home.newGame.desc')}</p>
          <span class="card-cta card-cta-dim">{t('home.newGame.cta')}</span>
        </div>
      </a>

    </div>
  </div>
</section>

<!-- ─── Support ────────────────────────────────────────────── -->
<section class="support-section">
  <div class="container">
    <div class="support-card">
      <p class="support-heading">{t('home.support.heading')}</p>
      <p class="support-sub">{t('home.support.sub')}</p>
      <a href="https://ko-fi.com/cappgames" target="_blank" rel="noopener" class="kofi-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.349 2.658-3.886-.025-1.502-.157-1.996-.157-1.996 0 0 3.555.07 5.063-1.583 1.498-1.645.576-3.185.576-3.185zm-13.37 7.214h-2.141V7.571h2.141v8.591zm3.855 0h-2.141v-5.56h2.141v5.56zm0-7.697h-2.141V6.276h2.141v2.189zm4.965 7.697h-2.141v-2.756l-2.141-3.066h2.523l.879 1.614.879-1.614h2.523l-2.141 3.066v2.756h-.381z"/>
        </svg>
        {t('home.support.kofi')}
      </a>
    </div>
  </div>
</section>

<!-- ─── Hero ─────────────────────────────────────────────── -->
<section class="hero">
  <div class="hero-content">
    <img src="/images/capp-logo.png" alt="CAPP GAMES" class="hero-logo" fetchpriority="high" />
    <h1 class="hero-title">CAPP GAMES</h1>
    <p class="hero-tagline">{t('home.hero.tagline')}</p>
  </div>
</section>

<!-- ─── Connect strip ────────────────────────────────────── -->
<section class="connect">
  <div class="container connect-inner">
    <div class="connect-left">
      <h2>{t('home.connect.heading')}</h2>
      <p>{t('home.connect.sub')}</p>
    </div>
    <div class="connect-links">
      <a href="https://www.instagram.com/cappgames/" target="_blank" rel="noopener" class="connect-pill pill-ig">IG @cappgames</a>
      <a href="https://www.instagram.com/ransack_game/" target="_blank" rel="noopener" class="connect-pill pill-ig">IG @ransack_game</a>
      <a href="https://boardgamegeek.com/profile/cappgames" target="_blank" rel="noopener" class="connect-pill pill-bgg">BGG cappgames</a>
      <a href="https://www.linkedin.com/in/carlospinedap/" target="_blank" rel="noopener" class="connect-pill pill-li">LinkedIn</a>
      <a href="https://discord.gg/8C9Z48nBRy" target="_blank" rel="noopener" class="connect-pill pill-dc">Discord</a>
      <a href="/about#contact" class="connect-pill pill-email">{t('home.connect.contact')}</a>
    </div>
    <a href="/about" class="connect-more">{t('home.connect.more')}</a>
  </div>
</section>

<style>
  /* ─── Hero ───────────────────────────────────────────────── */
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 3rem 1.5rem 3.5rem;
    background:
      radial-gradient(ellipse 80% 50% at 50% 50%, rgba(245,192,0,0.05) 0%, transparent 70%),
      var(--bg);
    border-top: 1px solid var(--border);
  }

  .hero-content {
    max-width: 640px;
    margin: 0 auto;
  }

  .hero-logo {
    width: clamp(100px, 16vw, 150px);
    height: auto;
    margin-bottom: 0.75rem;
    filter: drop-shadow(0 0 40px rgba(245,192,0,0.3));
  }

  .hero-title {
    color: var(--gold);
    margin-bottom: 0.5rem;
  }

  .hero-tagline {
    font-family: 'Cinzel', serif;
    font-size: clamp(1rem, 2.5vw, 1.4rem);
    color: var(--text-dim);
    margin-bottom: 0;
    letter-spacing: 0.06em;
  }

  /* ─── Products ───────────────────────────────────────────── */
  .products {
    padding: 0.75rem 0 5rem;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--text);
  }

  .product-card-featured {
    margin-bottom: 1.5rem;
    position: relative;
  }

  .card-overlay-link {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .featured-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
    margin-top: 0.25rem;
  }

  .play-now-btn {
    font-size: 0.95rem;
    padding: 0.6rem 1.5rem;
  }

  .details-link {
    color: var(--text-dim);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: color 0.2s;
  }
  .details-link:hover { color: var(--gold); }

  .featured-img-wrap {
    aspect-ratio: 3/1;
    max-height: 220px;
  }

  .featured-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .featured-title {
    font-size: 1.4rem;
    color: var(--text);
  }

  .update-teaser {
    color: var(--text-dim);
    font-style: italic;
    border-left: 2px solid rgba(120,180,255,0.3);
    padding-left: 0.75rem;
  }

  .board-games-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .card-img-wrap {
    width: 100%;
    aspect-ratio: 4/3;
    overflow: hidden;
    background: #1a1a1a;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .card-img-down {
    object-position: 50% 37.5%;
  }
  .product-card:hover .card-img {
    transform: scale(1.04);
  }

  .fa-hex-card {
    position: relative;
    background: #050b18;
    overflow: hidden;
  }

  .fa-hex-svg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .fa-overlay-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    z-index: 1;
  }

  .fa-heroes {
    display: flex;
    gap: 2.2rem;
    font-size: 2.86rem;
  }

  .fa-label {
    font-family: 'Cinzel', serif;
    font-size: 2.3rem;
    letter-spacing: 0.12em;
    background: linear-gradient(90deg, #f0c040, #f08040);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card-body {
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card-body h3 {
    font-size: 1.2rem;
    color: var(--text);
  }

  .card-desc {
    color: var(--text-dim);
    font-size: 0.9rem;
    margin: 0;
    flex: 1;
  }

  .card-cta {
    color: var(--gold);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-top: 0.25rem;
  }

  .card-cta-dim {
    color: var(--text-dim);
  }

  .product-card-soon {
    opacity: 0.75;
  }

  /* ─── Support ───────────────────────────────────────────── */
  .support-section {
    padding: 3rem 0;
    border-top: 1px solid var(--border);
  }

  .support-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 2.5rem 2rem;
    max-width: 540px;
    margin: 0 auto;
  }

  .support-heading {
    color: var(--gold);
    font-family: 'Cinzel', serif;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .support-sub {
    color: var(--text-dim);
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
    max-width: 380px;
  }

  .kofi-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 0.5rem;
    padding: 0.6rem 1.4rem;
    background: #FF5E5B;
    color: #ffffff;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    box-shadow: 0 3px 12px rgba(255,94,91,0.35);
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .kofi-btn:hover {
    transform: scale(1.05);
    box-shadow: 0 5px 18px rgba(255,94,91,0.55);
  }

  /* ─── Connect strip ──────────────────────────────────────── */
  .connect {
    border-top: 1px solid var(--border);
    padding: 3rem 0 4rem;
    background:
      radial-gradient(ellipse 60% 80% at 50% 100%, rgba(245,192,0,0.04) 0%, transparent 70%),
      var(--bg);
  }

  .connect-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .connect-left h2 {
    margin-bottom: 0.4rem;
  }

  .connect-left p {
    color: var(--text-dim);
    margin: 0;
    font-size: 0.95rem;
  }

  .connect-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .connect-pill {
    display: inline-block;
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-decoration: none;
    border: 1px solid transparent;
    transition: opacity 0.2s, transform 0.15s;
  }
  .connect-pill:hover { opacity: 0.85; transform: translateY(-1px); }

  .pill-ig   { background: rgba(225,48,108,0.15); color: #f06090; border-color: rgba(225,48,108,0.3); }
  .pill-bgg  { background: rgba(255,81,0,0.12);   color: #ff8040; border-color: rgba(255,81,0,0.3); }
  .pill-li   { background: rgba(0,119,181,0.15);  color: #5aaad8; border-color: rgba(0,119,181,0.3); }
  .pill-dc   { background: rgba(88,101,242,0.15);  color: #8b96f8; border-color: rgba(88,101,242,0.35); }
  .pill-email{ background: rgba(245,192,0,0.1);   color: var(--gold); border-color: rgba(245,192,0,0.3); }

  .connect-more {
    color: var(--text-dim);
    font-size: 0.85rem;
    text-decoration: none;
    transition: color 0.2s;
  }
  .connect-more:hover { color: var(--gold); }

  .tag-update {
    background: rgba(100,160,255,0.12);
    color: #80b8ff;
    border-color: rgba(100,160,255,0.3);
  }

  @media (max-width: 640px) {
    .hero {
      min-height: unset;
      padding: 2.5rem 1.5rem 1.5rem;
    }

    .board-games-row {
      grid-template-columns: 1fr;
    }
  }
</style>
