---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Board Games"
  description="CAPP GAMES board games — Ransack (published) and a new water-themed game in development."
>
  <section class="page">
    <div class="container">
      <div class="section-header">
        <h1>Board Games</h1>
        <div class="gold-divider"></div>
        <p class="page-sub">Physical games you can hold in your hands.</p>
      </div>

      <a href="/" class="back-link page-back">&#8592; Home</a>

      <div class="game-grid">

        <!-- Ransack -->
        <a href="/board-games/ransack" class="card game-card">
          <div class="card-img-wrap">
            <img src="/images/ransack-cover.png" alt="Ransack box cover" class="card-img" />
          </div>
          <div class="card-body">
            <div class="card-top">
              <span class="tag tag-gold">Published</span>
            </div>
            <h2>Ransack</h2>
            <p class="card-desc">
              A dark-fantasy card game for 3–6 players. Steal treasure, dodge monsters,
              and outwit rival thieves to escape the dungeon victorious.
            </p>
            <div class="card-meta">
              <span>3 – 6 Players</span>
              <span class="dot">&#183;</span>
              <span>20 – 30 min</span>
              <span class="dot">&#183;</span>
              <span>Age 10+</span>
            </div>
            <span class="card-cta">View Game &rarr;</span>
          </div>
        </a>

        <!-- New game (unnamed) -->
        <a href="/board-games/new-game" class="card game-card game-card-soon">
          <div class="card-img-wrap">
            <img src="/images/UpcomingWaterGame.png" alt="New water-themed board game in development" class="card-img" />
          </div>
          <div class="card-body">
            <div class="card-top">
              <span class="tag tag-gray">In Development</span>
            </div>
            <h2>Designing Something New</h2>
            <p class="card-desc">
              A new water-themed board game is in the works.
              More details when the time is right.
            </p>
            <div class="card-meta card-meta-dim">
              <span>Details TBD</span>
            </div>
            <span class="card-cta card-cta-dim">Peek In &rarr;</span>
          </div>
        </a>

      </div>
    </div>
  </section>
</Layout>

<style>
  .page {
    padding: 3rem 0 5rem;
  }

  .page-sub {
    color: var(--text-dim);
    font-size: 1.05rem;
    margin: 0;
  }

  .page-back {
    display: inline-flex;
    margin-bottom: 1rem;
  }

  .game-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .game-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--text);
  }

  .card-img-wrap {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: #1a1a1a;
  }

  .card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }
  .card-img-top {
    object-position: 50% 12.5%;
  }
  .game-card:hover .card-img {
    transform: scale(1.04);
  }

  .card-img-ocean {
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #020d1a, #052840);
  }

  .mystery-q {
    font-size: 3.5rem;
    color: rgba(100,180,255,0.3);
    font-family: 'Cinzel', serif;
    font-weight: 700;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    flex: 1;
  }

  .card-top { margin-bottom: 0.25rem; }

  .card-body h2 {
    font-size: 1.5rem;
    color: var(--text);
  }

  .card-desc {
    color: var(--text-dim);
    font-size: 0.95rem;
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--gold);
    font-weight: 500;
  }

  .card-meta-dim { color: var(--text-dim); }

  .dot { opacity: 0.4; }

  .card-cta {
    color: var(--gold);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
  }

  .card-cta-dim { color: var(--text-dim); }
  .game-card-soon { opacity: 0.8; }
</style>
