---
import Layout from '../../../layouts/Layout.astro';
import VideoGamesIndexPage from '../../../components/VideoGamesIndexPage.astro';
import { useTranslations } from '../../../i18n/ui';

const t = useTranslations('es');

const collectionLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${t('videogames.h1')} — CAPP GAMES`,
  description: t('videogames.description'),
  url: 'https://capp-games.com/es/video-games',
  inLanguage: 'es',
  isPartOf: { '@type': 'WebSite', name: 'CAPP GAMES', url: 'https://capp-games.com' },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        item: {
          '@type': 'VideoGame',
          name: 'Auto-Chess: Fantasy Arena',
          url: 'https://capp-games.com/es/video-games/fantasy-arena',
        },
      },
    ],
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://capp-games.com/es' },
    { '@type': 'ListItem', position: 2, name: 'Videojuegos', item: 'https://capp-games.com/es/video-games' },
  ],
};

const jsonLd = [collectionLd, breadcrumbLd];
---

<Layout title={t('videogames.title')} description={t('videogames.description')} lang="es" jsonLd={jsonLd}>
  <VideoGamesIndexPage lang="es" />
</Layout>
