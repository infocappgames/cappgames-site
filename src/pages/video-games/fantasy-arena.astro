---
import Layout from '../../layouts/Layout.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'VideoGame',
  name: 'Auto-Chess: Fantasy Arena',
  description: 'Free browser strategy game. Summon heroes, deploy them on a hex grid, and conquer The Abyss.',
  url: 'https://cappgames.com/video-games/fantasy-arena',
  image: 'https://cappgames.com/images/fantasy-arena-banner.png',
  gamePlatform: 'Web Browser',
  applicationCategory: 'Game',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  publisher: { '@type': 'Organization', name: 'CAPP GAMES' },
  author: { '@type': 'Person', name: 'Andrés Pineda' },
};
---

<Layout
  title="Auto-Chess: Fantasy Arena"
  description="Auto-Chess: Fantasy Arena — free browser strategy game by CAPP GAMES. Summon heroes, deploy on a hex grid, and conquer The Abyss. No download required."
  ogImage="/images/fantasy-arena-banner.png"
  jsonLd={jsonLd}
>
  <!-- ─── Hero ─────────────────────────────────────────────── -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true">
      <img src="/images/fantasy-arena-banner.png" alt="" class="hero-banner-img" />
      <div class="hero-overlay"></div>
    </div>
    <div class="hero-content container">
      <a href="/video-games" class="back-link">&#8592; Video Games</a>
      <div class="hero-badge">Free Browser Game</div>
      <h1>Auto-Chess:<br /><span class="gold">Fantasy Arena</span></h1>
      <p class="hero-desc">
        Summon powerful heroes through a gacha system, deploy them on a hex grid, and watch
        automated battles unfold. Progress through rounds of escalating challenge — monsters,
        hybrid bosses, and the terrifying secret end-game: <strong>The Abyss</strong>.
      </p>
      <a
        href="https://fantasy-arena-iota.vercel.app"
        target="_blank"
        rel="noopener"
        class="btn btn-gold play-btn"
      >
        &#9658; Play Now — Free
      </a>
    </div>
  </section>

  <!-- ─── Stats ─────────────────────────────────────────────── -->
  <div class="stats-bar">
    <div class="container stats-inner">
      <div class="stat">
        <span class="stat-icon">&#128176;</span>
        <span class="stat-label">Free to Play</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-icon">&#127760;</span>
        <span class="stat-label">Browser — No Install</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-icon">&#129490;</span>
        <span class="stat-label">Single-Player</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-icon">&#127942;</span>
        <span class="stat-label">Top Scoreboard</span>
      </div>
    </div>
  </div>

  <!-- ─── How to Play ──────────────────────────────────────── -->
  <section class="features">
    <div class="container">

      <!-- What is the game -->
      <div class="section-header">
        <h2>What is Fantasy Arena?</h2>
        <div class="gold-divider"></div>
      </div>
      <p class="game-intro">Auto-Chess: Fantasy Arena is a free single-player strategy game that runs entirely in your browser — no download, no account required. Each run you summon a team of heroes through a gacha system, position them on a hex grid, and watch automated battles play out round by round. Every run is different: enemy forces change, your pulls are random, and your decisions on who to keep, sell, or upgrade define whether you survive long enough to face what waits at Round 20.</p>

      <!-- Heroes -->
      <div class="section-header" style="margin-top:3rem">
        <h2>Heroes</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="hero-grid">
        <div class="hero-card">
          <div class="hero-icon">&#9876;&#65039;</div>
          <div class="hero-name">Warrior</div>
          <span class="role-badge role-tank">Tank</span>
          <p class="hero-traits">Melee · High HP · Absorbs hits</p>
        </div>
        <div class="hero-card">
          <div class="hero-icon">&#128154;</div>
          <div class="hero-name">Healer</div>
          <span class="role-badge role-support">Support</span>
          <p class="hero-traits">Heals allies · Fastest · Vital</p>
        </div>
        <div class="hero-card">
          <div class="hero-icon">&#128481;&#65039;</div>
          <div class="hero-name">Assassin</div>
          <span class="role-badge role-finisher">Finisher</span>
          <p class="hero-traits">Targets weakest · Executes · Pursues</p>
        </div>
        <div class="hero-card">
          <div class="hero-icon">&#127993;</div>
          <div class="hero-name">Archer</div>
          <span class="role-badge role-sniper">Sniper</span>
          <p class="hero-traits">Long range · Retreats · Fast</p>
        </div>
        <div class="hero-card">
          <div class="hero-icon">&#129497;</div>
          <div class="hero-name">Mage</div>
          <span class="role-badge role-aoe">AoE Blaster</span>
          <p class="hero-traits">Ranged · Splashes damage · Slow</p>
        </div>
      </div>

      <!-- How to Play -->
      <div class="section-header" style="margin-top:3rem">
        <h2>How to Play</h2>
        <div class="gold-divider"></div>
      </div>

      <div class="steps-row">
        <div class="step-card">
          <div class="step-icon">&#127922;</div>
          <div class="step-name">Discover</div>
          <div class="step-desc">Pull free heroes</div>
        </div>
        <div class="step-arrow">&rarr;</div>
        <div class="step-card">
          <div class="step-icon">&#128722;</div>
          <div class="step-name">Shop</div>
          <div class="step-desc">Buy &amp; sell heroes</div>
        </div>
        <div class="step-arrow">&rarr;</div>
        <div class="step-card">
          <div class="step-icon">&#128212;</div>
          <div class="step-name">Deploy</div>
          <div class="step-desc">Place your team</div>
        </div>
        <div class="step-arrow">&rarr;</div>
        <div class="step-card">
          <div class="step-icon">&#9876;&#65039;</div>
          <div class="step-name">Battle</div>
          <div class="step-desc">Watch them fight</div>
        </div>
        <div class="step-arrow">&rarr;</div>
        <div class="step-card">
          <div class="step-icon">&#128176;</div>
          <div class="step-name">Loot</div>
          <div class="step-desc">Collect rewards</div>
        </div>
      </div>

      <!-- Tips -->
      <div class="section-header" style="margin-top:3rem">
        <h2>Tips</h2>
        <div class="gold-divider"></div>
      </div>

      <ul class="tips-list">
        <li>3 copies of the same hero merge into a higher rarity</li>
        <li>You can sell unwanted heroes in the Shop for gold</li>
        <li>Each run the enemy forces are different — adapt your strategy</li>
        <li>Survive deeper rounds to claim your place in the Hall of Champions</li>
        <li>Win Round 20 to discover what waits beyond…</li>
      </ul>

      <!-- CTA -->
      <div class="play-cta">
        <a href="https://fantasy-arena-iota.vercel.app" target="_blank" rel="noopener" class="btn btn-gold">
          &#9658; Play Now — Free
        </a>
        <p class="play-note">No account required. Runs in any modern browser.</p>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* ─── Hero ───────────────────────────────────────────────── */
  .hero {
    position: relative;
    padding: 5rem 0 4rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-banner-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 65%;
    display: block;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to right, rgba(10,10,10,0.82) 40%, rgba(10,10,10,0.3) 100%),
      linear-gradient(to top, rgba(10,10,10,0.6) 0%, transparent 40%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    background: rgba(91,175,245,0.12);
    color: #5baff5;
    border: 1px solid rgba(91,175,245,0.3);
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }

  .hero h1 {
    margin-bottom: 1.25rem;
    line-height: 1.15;
  }

  .hero-desc {
    font-size: 1.05rem;
    color: var(--text-dim);
    line-height: 1.75;
    max-width: 580px;
    margin-bottom: 2rem;
  }

  .play-btn {
    font-size: 1.1rem;
    padding: 1rem 2.5rem;
  }

  /* ─── Stats bar ──────────────────────────────────────────── */
  .stats-bar {
    background: var(--card-bg);
    border-top: 1px solid rgba(91,175,245,0.4);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .stat {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .stat-icon { font-size: 1.1rem; }
  .stat-label { font-size: 0.9rem; font-weight: 500; }
  .stat-divider {
    width: 1px;
    height: 20px;
    background: var(--border);
  }

  /* ─── How to Play ────────────────────────────────────────── */
  .features {
    padding: 2rem 0 5rem;
  }

  /* Intro */
  .game-intro {
    font-size: 1rem;
    color: var(--text-dim);
    line-height: 1.8;
    margin: 0 0 1rem;
  }

  /* Steps */
  .steps-row {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .step-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1rem;
    text-align: center;
    width: 120px;
    transition: border-color 0.2s;
  }
  .step-card:hover { border-color: var(--gold); }

  .step-icon { font-size: 1.8rem; margin-bottom: 0.5rem; }
  .step-name { font-family: 'Cinzel', serif; font-size: 0.9rem; color: var(--gold); margin-bottom: 0.3rem; }
  .step-desc { font-size: 0.78rem; color: var(--text-dim); }

  .step-arrow {
    color: var(--text-dim);
    font-size: 1.2rem;
    flex-shrink: 0;
  }

  /* Heroes */
  .hero-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1rem;
  }

  .hero-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 0.75rem;
    text-align: center;
    transition: border-color 0.2s;
  }
  .hero-card:hover { border-color: rgba(91,175,245,0.5); }

  .hero-icon { font-size: 2rem; margin-bottom: 0.5rem; }
  .hero-name { font-family: 'Cinzel', serif; font-size: 0.95rem; color: var(--text); margin-bottom: 0.5rem; }

  .role-badge {
    display: inline-block;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
  }
  .role-tank     { background: rgba(80,120,220,0.2); color: #7aabff; }
  .role-support  { background: rgba(80,200,120,0.2); color: #6fdda0; }
  .role-finisher { background: rgba(220,60,60,0.2);  color: #ff8080; }
  .role-sniper   { background: rgba(180,140,60,0.2); color: #e0b84a; }
  .role-aoe      { background: rgba(150,80,220,0.2); color: #c090ff; }

  .hero-traits {
    font-size: 0.78rem;
    color: var(--text-dim);
    margin: 0;
    line-height: 1.5;
  }

  /* Tips */
  .tips-list {
    list-style: none;
    padding: 0;
    margin: 0 0 3rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .tips-list li {
    font-size: 0.95rem;
    color: var(--text-dim);
    padding-left: 1.4rem;
    position: relative;
    line-height: 1.6;
  }

  .tips-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--gold);
  }

  /* Play CTA */
  .play-cta {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .play-note {
    color: var(--text-dim);
    font-size: 0.85rem;
    margin: 0;
  }

  @media (max-width: 768px) {
    .hero-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .step-arrow { display: none; }
    .steps-row { gap: 0.75rem; }
  }

  @media (max-width: 600px) {
    .stat-divider { display: none; }
    .hero-grid { grid-template-columns: repeat(2, 1fr); }
    .step-card { width: 100px; }
  }
</style>
